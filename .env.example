# Anthropic API Key（既存のAPIキーをコピー）
ANTHROPIC_API_KEY=sk-ant-api03-...

# X (Twitter) API Keys
# 取得場所: https://developer.twitter.com/en/portal/projects-and-apps
# 新規App作成 → Keys and Tokens → Generate
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Cron Secret（任意の文字列・Vercel環境変数にも同じ値を設定）
CRON_SECRET=sns2026secret_pokkori

# Qiita自動記事投稿（オプション）
QIITA_ACCESS_TOKEN=your_qiita_token_here
